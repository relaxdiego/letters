# Hugo build output. Nothing here is worth keeping — it is all regenerated
# from content/ and layouts/ by running `hugo`.
/public/
/resources/
.hugo_build.lock

# devbox / direnv. devbox.json and devbox.lock ARE committed; the rest is
# local machine state. .envrc.local is yours alone, .envrc is shared.
.devbox/
.envrc.*
!.envrc

# Claude Code skills live here and are meant to be shared via this repo,
# unlike your global gitignore's default of hiding .claude/.
!.claude/
